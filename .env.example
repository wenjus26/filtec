# Django Configuration
SECRET_KEY=django-insecure-your-secret-key-goes-here
DEBUG=False
ALLOWED_HOSTS=web.filtec.in,localhost,127.0.0.1

# CSRF Trusted Origins (required in production behind Nginx)
# Include full scheme: https:// or http://
CSRF_TRUSTED_ORIGINS=https://web.filtec.in,http://web.filtec.in

# Database Configuration (supports sqlite, mysql, postgresql)
# Options: sqlite, mysql, postgresql
DB_ENGINE=sqlite
DB_NAME=db.sqlite3

# For MySQL / PostgreSQL:
# DB_ENGINE=postgresql
# DB_NAME=filtec_db
# DB_USER=filtec_user
# DB_PASSWORD=filtec_pass
# DB_HOST=db
# DB_PORT=5432

# Or alternatively supply a DATABASE_URL:
# DATABASE_URL=postgres://filtec_user:filtec_pass@db:5432/filtec_db
